{
  "manifest_version": 3,
  "name": "Slack PWA",
  "description": "Convert Slack web app to PWA",
  "version": "1.2.1",
  "author": "Anshu Meena <hi@gxanshu.in>",
  "icons": {
    "16": "assets/16x16.png",
    "48": "assets/48x48.png",
    "128": "assets/128x128.png"
  },
  "action": {},
  "permissions": ["offscreen", "scripting"],
  "host_permissions": ["*://app.slack.com/*"],
  "background": {
    "service_worker": "pwa/sw.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://app.slack.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://app.slack.com/*"],
      "js": ["badge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/notify.mp3", "pwa/offscreen.html", "pwa/offscreen.js"],
      "matches": ["*://app.slack.com/*"]
    }
  ]
}
