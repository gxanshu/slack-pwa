{
  "manifest_version": 3,
  "name": "Slack PWA",
  "description": "Convert Slack web app to PWA",
  "version": "1.1.1",
  "author": "Anshu Meena <anshu@frimware.in>",
  "icons": {
    "16": "assets/16x16.png",
    "48": "assets/48x48.png",
    "128": "assets/128x128.png"
  },
  "permissions": ["offscreen", "storage"],
  "host_permissions": ["*://app.slack.com/*"],
  "background": {
    "service_worker": "pwa/sw.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://app.slack.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [{
    "resources": ["assets/notify.mp3", "pwa/offscreen.html", "pwa/offscreen.js"],
    "matches": ["<all_urls>"]
  }]
}
